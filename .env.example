# ---- MongoDB ----
# Local:  mongodb://127.0.0.1:27017/himalayan-flames
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/himalayan-flames?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/himalayan-flames

# ---- NextAuth (Auth.js v5) ----
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string
# Public URL of the app (used for callbacks). Optional in dev.
NEXTAUTH_URL=http://localhost:3000

# ---- Seed admin account (used by `npm run seed`) ----
ADMIN_NAME=Owner
ADMIN_EMAIL=owner@himalayanflames.com
ADMIN_PASSWORD=HimalayanFlames2024!

# ---- Contact form email (Resend) ----
# Get a free API key at https://resend.com (sign up with the inbox address below).
# If RESEND_API_KEY is unset, the form still saves messages to the DB but won't email.
RESEND_API_KEY=
# Inbox that receives contact-form messages.
CONTACT_TO=thehimalayanflames@gmail.com
# From address. Use onboarding@resend.dev until you verify your own domain in Resend.
CONTACT_FROM=Himalayan Flames <onboarding@resend.dev>
